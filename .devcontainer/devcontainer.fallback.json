{
  "name": "agentize.eu PoC Environment (fallback local image)",
  "build": {
    "dockerfile": "Dockerfile.fallback"
  },
  "forwardPorts": [8000, 27017],
  "remoteUser": "root",
  "containerEnv": {
    "DEVCONTAINER_SCOPE": "root",
    "DEVCONTAINER_MODE": "fallback"
  },
  "postCreateCommand": "pip install -r poc-backend/requirements.txt && pip install -e poc-backend/[dev]",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "python.linting.enabled": true,
        "python.linting.flake8Enabled": true,
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-azuretools.vscode-docker",
        "ms-vscode.azure-account",
        "ms-azuretools.vscode-bicep",
        "TeamsDevApp.ms-teams-vscode-extension"
      ]
    }
  }
}
